# ─────────────────────────────────────────
# COPIA ESTE ARCHIVO COMO .env Y RELLENA
# No subas el .env real a GitHub nunca
# ─────────────────────────────────────────

# Tu clave de Anthropic (Claude)
# Consíguela en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Token secreto para verificar webhooks de Meta
# Puedes poner cualquier palabra que recuerdes, ej: miagente2024
VERIFY_TOKEN=miagente2024

# Token de WhatsApp Business API
# Lo obtienes en: Meta Developers > tu app > WhatsApp > API Setup
WHATSAPP_TOKEN=

# Token de Instagram Graph API
# Lo obtienes en: Meta Developers > tu app > Instagram > Tokens
INSTAGRAM_TOKEN=

# Instrucciones del agente (personaliza tu marca)
AGENT_INSTRUCTIONS=Eres un agente de atención al cliente de [TU MARCA]. Responde siempre en español, con tono cercano y profesional. Máximo 3-4 frases. Si preguntan precios, di que un miembro del equipo les contactará. Firma siempre como "El equipo de [TU MARCA]".

# Puerto (Railway lo pone automáticamente, no cambies)
PORT=3000
